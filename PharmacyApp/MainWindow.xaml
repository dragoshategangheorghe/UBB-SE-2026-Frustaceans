<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="PharmacyApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PharmacyApp"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="PharmacyApp">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!--topbar-->
            <RowDefinition Height="*"/>
            <!--page-->
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="White" Padding="20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal"
                Spacing="15"
                VerticalAlignment="Center">

                <Button Background="Transparent"
                    BorderBrush="Transparent"
                    Click="OnHomeClicked">
                    
                    <TextBlock Text="Home"
                        Foreground="#389e7c"
                        FontSize="16"
                        FontWeight="SemiBold"/>
                </Button>

                <Button Background="Transparent"
                    BorderBrush="Transparent"
                    Click="OnProductsClicked">
                    <TextBlock Text="Products"
                        Foreground="#389e7c"
                        FontSize="16"
                        FontWeight="SemiBold"/>
                </Button>

                <Button x:Name="AdminButton"
                        Visibility="Collapsed"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Click="OnAdminClicked">
                    <TextBlock Text="Admin Dashboard"
                        Foreground="#389e7c"
                        FontSize="16"
                        FontWeight="SemiBold"/>
                </Button>
                <Button x:Name="AdminUsersButton"
                        Visibility="Collapsed"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Click="OnAdminUsersClicked">
                    <TextBlock Text="User Accounts"
                        Foreground="#389e7c"
                        FontSize="16"
                        FontWeight="SemiBold"/>
                </Button>

                <Button x:Name="PeriodTrackerButton"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Click="OnPeriodTrackerClicked">
                    <TextBlock Text="Period Tracker"
                               Foreground="#389e7c"
                               FontSize="16"
                               FontWeight="SemiBold"/>
                </Button>

            </StackPanel>
            <Image Grid.Column="1"
                Source="ms-appx:///Assets/logo.png"
                Height="40"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"/>
            <StackPanel Grid.Column="2"
                Orientation="Horizontal"
                Spacing="15"
                VerticalAlignment="Center"
                HorizontalAlignment="Right">

                <Button Content="🛒"
                Click="OnCartClicked"
                FontSize="16"
                FontWeight="SemiBold"
                FontFamily="Segoe UI"
                Background="Transparent"
                Foreground="#4CAF50"
                BorderBrush="Transparent"/>

                <Button Content="👤" x:Name="AccountButton"
                FontSize="16"
                Visibility="Collapsed"
                FontWeight="SemiBold"
                FontFamily="Segoe UI"
                Click="OnAccountClicked"
                Background="Transparent"
                Foreground="#4CAF50"
                BorderBrush="Transparent"/>
                
                <Button x:Name="LoginButton"
                        Visibility="Visible"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Click="OnLoginClicked">
                    <TextBlock Text="Login"
                        Foreground="#389e7c"
                        FontSize="16"
                        FontWeight="SemiBold"/>
                </Button>
                <Button x:Name="RegisterButton"
                        Visibility="Visible"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Click="OnRegisterClicked">
                    <TextBlock Text="Register"
                        Foreground="#389e7c"
                        FontSize="16"
                        FontWeight="SemiBold"/>
                </Button>

            </StackPanel>
        </Grid>

        <Frame x:Name="MainFrame" Grid.Row="1"/>
    </Grid>
</Window>