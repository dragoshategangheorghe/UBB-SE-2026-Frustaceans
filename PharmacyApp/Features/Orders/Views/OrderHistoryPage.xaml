<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PharmacyApp.Features.Orders.Views.OrderHistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:model="using:PharmacyApp.Models"
    xmlns:viewModel="using:PharmacyApp.Features.Orders.ViewModels"
    xmlns:local="using:PharmacyApp.Features.Orders.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Name="PageRoot">

    
    <Page.Resources>

        <!-- I'll try to use Style for practice -->
        <!-- TODO how to share style setters between styles? -->
        <Style TargetType="TextBlock" x:Key="ExpiredTextStyle">
            <Setter Property="Foreground" Value="Red"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Button" x:Key="ExpiredButtonStyle">
            <Setter Property="Width" Value="100"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Background" Value="Red"/>
        </Style>


        <Style TargetType="TextBlock" x:Key="CompletedTextStyle">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>


        <Style TargetType="TextBlock" x:Key="IncompletedTextStyle">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Button" x:Key="IncompletedButtonStyle">
            <Setter Property="Width" Value="100"/>
            <Setter Property="CornerRadius" Value="5"/>
        </Style>


        <!-- declaring data templates for every status
        and a data template selector at the end -->
        <DataTemplate x:Key="CompletedTemplate" x:DataType="model:Order">

            <Grid ColumnDefinitions="*, 2*, 2*, *, *, *">

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="{x:Bind IdString}"
                           Style="{StaticResource CompletedTextStyle}"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Text="{x:Bind PickUpDateString}"
                           Style="{StaticResource CompletedTextStyle}"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="2"
                           Text="{x:Bind ExpirationDateString}"
                           Style="{StaticResource CompletedTextStyle}"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="3"
                           Text="Completed"
                           Style="{StaticResource CompletedTextStyle}"/>

            </Grid>

        </DataTemplate>


        <DataTemplate x:Key="ExpiredTemplate" x:DataType="model:Order">

            <Grid ColumnDefinitions="*, 2*, 2*, *, *, *">

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="{x:Bind IdString}"
                           Style="{StaticResource ExpiredTextStyle}"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Text="{x:Bind PickUpDateString}"
                           Style="{StaticResource ExpiredTextStyle}"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="2"
                           Text="{x:Bind ExpirationDateString}"
                           Style="{StaticResource ExpiredTextStyle}"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="3"
                           Text="Expired"
                           Style="{StaticResource ExpiredTextStyle}"/>
                <Button Grid.Row="0"
                        Grid.Column="4"
                        Content="Resubmit"
                        Command="{Binding DataContext.ResubmitCommand, ElementName=PageRoot}"
                        CommandParameter="{Binding}"
                        Style="{StaticResource ExpiredButtonStyle}"/>

            </Grid>

        </DataTemplate>


        <DataTemplate x:Key="IncompletedTemplate" x:DataType="model:Order">

            <Grid ColumnDefinitions="*, 2*, 2*, *, *, *">

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="{x:Bind IdString}"
                           Style="{StaticResource IncompletedTextStyle}"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Text="{x:Bind PickUpDateString}"
                           Style="{StaticResource IncompletedTextStyle}"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="2"
                           Text="{x:Bind ExpirationDateString}"
                           Style="{StaticResource IncompletedTextStyle}"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="3"
                           Text="Incompleted"
                           Style="{StaticResource IncompletedTextStyle}"/>
                <Button Grid.Row="0"
                        Grid.Column="4"
                        Content="Cancel"
                        Command="{Binding DataContext.CancelCommand, ElementName=PageRoot}"
                        CommandParameter="{Binding}"
                        Style="{StaticResource IncompletedButtonStyle}"/>
                <Button Grid.Row="0"
                        Grid.Column="5"
                        Content="Modify"
                        Command="{Binding DataContext.GoToDetailPageCommand, ElementName=PageRoot}"
                        CommandParameter="{Binding}"
                        Style="{StaticResource IncompletedButtonStyle}"/>

            </Grid>

        </DataTemplate>


        <local:OrderTemplateSelector x:Key="OrderTemplateSelector"
                                     CompletedTemplate="{StaticResource CompletedTemplate}"
                                     ExpiredTemplate="{StaticResource ExpiredTemplate}"
                                     IncompletedTemplate="{StaticResource IncompletedTemplate}"/>

    </Page.Resources>
    
    
    <Grid Padding="100, 30, 100, 30" 
          RowDefinitions="Auto, *"
          ColumnDefinitions="*, Auto">

        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   Text="Your orders"
                   FontSize="30"
                   FontWeight="Bold"/>

        <CheckBox Grid.Row="0"
                  Grid.Column="1"
                  Content="Only expired orders"
                  IsChecked="{x:Bind ViewModel.IsExpiredCheckbox, Mode=TwoWay}"/>

        <ListView Grid.Row="1"
                  Grid.Column="0"
                  Grid.ColumnSpan="2"
                  x:Name="OrderListView"
                  ItemsSource="{x:Bind ViewModel.OrderHistory}"
                  ItemTemplateSelector="{StaticResource OrderTemplateSelector}">
        </ListView>

    </Grid>
</Page>
