<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PharmacyApp.Features.Orders.Views.OrderManagementPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PharmacyApp.Features.Orders.Views"
    xmlns:model="using:PharmacyApp.Features.Orders.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">


    <Page.Resources>

        <!-- I'll try to use Style for practice -->
        <!-- TODO how to share style setters between styles? -->
        <Style TargetType="TextBlock" x:Key="ExpiredTextStyle">
            <Setter Property="Foreground" Value="Red"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="NotExpiredTextStyle">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="CompleteTextStyle">
            <Setter Property="Foreground" Value="#80ffffff"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        

        <!-- defining item templates for orders -->
        <DataTemplate x:Key="ExpiredTemplate" x:DataType="model:OrderDetail">

            <Grid ColumnDefinitions="*, 2*, 2*, *, *">

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="{x:Bind OrderString}"
                           Style="{StaticResource ExpiredTextStyle}"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Text="{x:Bind UserEmail}"
                           Style="{StaticResource ExpiredTextStyle}"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="2"
                           Text="Expired"
                           Style="{StaticResource ExpiredTextStyle}"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="3"
                           Text="{x:Bind PickUpDateString}"
                           Style="{StaticResource ExpiredTextStyle}"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="4"
                           Text="{x:Bind ExpirationDateString}"
                           Style="{StaticResource ExpiredTextStyle}"/>

            </Grid>

        </DataTemplate>


        <DataTemplate x:Key="NotExpiredTemplate" x:DataType="model:OrderDetail">

            <Grid ColumnDefinitions="*, 2*, 2*, *, *">

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="{x:Bind OrderString}"
                           Style="{StaticResource NotExpiredTextStyle}"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Text="{x:Bind UserEmail}"
                           Style="{StaticResource NotExpiredTextStyle}"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="2"
                           Text="Incomplete"
                           Style="{StaticResource NotExpiredTextStyle}"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="3"
                           Text="{x:Bind PickUpDateString}"
                           Style="{StaticResource NotExpiredTextStyle}"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="4"
                           Text="{x:Bind ExpirationDateString}"
                           Style="{StaticResource NotExpiredTextStyle}"/>

            </Grid>

        </DataTemplate>
        

        <DataTemplate x:Key="CompleteTemplate" x:DataType="model:OrderDetail">

            <Grid ColumnDefinitions="*, 2*, 2*, *, *">

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="{x:Bind OrderString}"
                           Style="{StaticResource CompleteTextStyle}"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Text="{x:Bind UserEmail}"
                           Style="{StaticResource CompleteTextStyle}"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="2"
                           Text="Complete"
                           Style="{StaticResource CompleteTextStyle}"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="3"
                           Text="{x:Bind PickUpDateString}"
                           Style="{StaticResource CompleteTextStyle}"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="4"
                           Text="{x:Bind ExpirationDateString}"
                           Style="{StaticResource CompleteTextStyle}"/>

            </Grid>

        </DataTemplate>


        <!-- can I reuse the same class? hmm -->
        <!-- nope, cuz the underlying model class is not the same -->
        <local:OrderDetailTemplateSelector x:Key="OrderDetailTemplateSelector"
                                           ExpiredTemplate="{StaticResource ExpiredTemplate}"
                                           CompleteTemplate="{StaticResource CompleteTemplate}"
                                           IncompleteTemplate="{StaticResource NotExpiredTemplate}"/>

    </Page.Resources>
    

    <Grid Padding="20"
          ColumnDefinitions="*, 3*">

        <!-- filters -->
        <StackPanel Grid.Row="0"
                    Grid.Column="0"
                    Spacing="12">

            <TextBox Header="Order ID"
                     PlaceholderText="Enter order ID"
                     Text="{x:Bind ViewModel.OrderIDInput, Mode=TwoWay}"/>
            <TextBox Header="User e-mail"
                     PlaceholderText="Enter user e-mail"
                     Text="{x:Bind ViewModel.UserEmailInput, Mode=TwoWay}"/>
            <CheckBox Content="Only incomplete orders" 
                      IsChecked="{x:Bind ViewModel.IsIncompleteCheckbox, Mode=TwoWay}"/>
            <CheckBox Content="Only expired orders"
                      IsChecked="{x:Bind ViewModel.IsExpiredCheckbox, Mode=TwoWay}"/>

        </StackPanel>


        <!-- resulting list view -->
        <ListView Grid.Row="0"
                  Grid.Column="1"
                  ItemsSource="{x:Bind ViewModel.FilteredOrderList}"
                  ItemTemplateSelector="{StaticResource OrderDetailTemplateSelector}">

        </ListView>
        
    </Grid>
</Page>
