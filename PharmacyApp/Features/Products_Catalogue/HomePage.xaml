<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PharmacyApp.Features.Products_Catalogue.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PharmacyApp.Features.Products_Catalogue"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Image Source="ms-appx:///Assets/HomePageBackground.jpg" Stretch="UniformToFill"/>
        <StackPanel VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Spacing="10">
            <TextBlock Text="Welcome to PharmacyApp"
                   FontSize="36"
                   FontWeight="Bold"
                   Foreground="White"
                   TextAlignment="Center"/>
            <TextBlock Text="Your online store for medical needs"
                   FontSize="18"
                   Foreground="White"
                   TextAlignment="Center"
                   Width="500"
                   TextWrapping="WrapWholeWords"/>
        </StackPanel>
    </Grid>
</Page>
