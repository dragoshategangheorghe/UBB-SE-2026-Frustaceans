<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PharmacyApp.Features.Pharmacy_Management.StatisticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PharmacyApp.Features.Pharmacy_Management"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:PharmacyApp.Models"
    mc:Ignorable="d"
    RequestedTheme="Light"
    Background="White">

    <Page.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="Black"/>
        </Style>

    </Page.Resources>

    <ScrollViewer VerticalScrollMode="Enabled"
              HorizontalScrollMode="Enabled">

        <Grid>

            <!-- TOP NAV -->
            <Button Content="Edit Page"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="10"
                Click="GoToEditPageClick"/>

            <!-- SWITCH BUTTONS -->
            <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                    Margin="0,50,0,10"
                    Spacing="10">

                <Button Content="Items"
                    Click="OnItemsClick"
                    Background="#66d4af"/>

                <Button Content="Substances"
                    Click="OnSubstancesClick"
                    Background="#66d4af"/>
            </StackPanel>

            <!-- ITEMS GRID -->
            <StackPanel x:Name="ItemsGrid"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,100,0,0"
                    Spacing="10">

                <TextBlock Text="Top 30 Most Ordered Items"
                       FontSize="20"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>

                <Grid Width="600"
                  Height="400"
                  BorderBrush="Gray"
                  BorderThickness="1">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- HEADER -->
                    <Grid Grid.Row="0" Background="#EEE" Padding="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Item ID" Grid.Column="0" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Item Name" Grid.Column="1" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Orders" Grid.Column="2" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </Grid>

                    <!-- LIST -->
                    <ListView Grid.Row="1"
                          ItemsSource="{x:Bind TopItems}">

                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="x:Object">
                                <Border BorderBrush="Gray"
                                    BorderThickness="0,0,0,1"
                                    Padding="5">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Item1}" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Item2}" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Item3}" HorizontalAlignment="Center"/>
                                    </Grid>

                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>

                    </ListView>

                </Grid>
            </StackPanel>

            <!-- SUBSTANCES GRID -->
            <StackPanel x:Name="SubstancesGrid"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,100,0,0"
                    Spacing="10">

                <TextBlock Text="Top 20 Most Popular Substances"
                       FontSize="20"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>

                <Grid Width="600"
                  Height="400"
                  BorderBrush="Gray"
                  BorderThickness="1">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- HEADER -->
                    <Grid Grid.Row="0" Background="#EEE" Padding="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Name" Grid.Column="0" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Number of Orders" Grid.Column="1" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </Grid>

                    <!-- LIST -->
                    <ListView Grid.Row="1"
                              ItemsSource="{x:Bind TopSubstances}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="x:Object">
                                <Border BorderBrush="Gray"
                                        BorderThickness="0,0,0,1"
                                        Padding="5">    

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Key}" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Value}" HorizontalAlignment="Center"/>
                                    </Grid>

                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                </Grid>
            </StackPanel>

        </Grid>
    </ScrollViewer>
</Page>
