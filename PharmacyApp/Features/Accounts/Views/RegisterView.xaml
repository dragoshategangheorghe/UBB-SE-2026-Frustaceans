<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PharmacyApp.Features.Accounts.Views.RegisterView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PharmacyApp.Features.Accounts.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>

        <!--for the box-->
        <SolidColorBrush x:Key="TextControlBackground" Color="White"/>
        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#389e7c"/>
        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="White"/>


        <!--for the text-->
        <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#389e7c"></SolidColorBrush>
        <SolidColorBrush x:Key="TextControlForeground" Color="#389e7c"></SolidColorBrush>
        <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="White"></SolidColorBrush>
        <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#389e7c"></SolidColorBrush>
        <SolidColorBrush x:Key="TextControlSelectionHighlightColor" Color="#389e7c"></SolidColorBrush>

        <!--button stuff-->
        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#C8E6C9"/>
        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#C8E6C9"/>

    </Page.Resources>

    <Grid Background="White">
        <Border
            Width="320"
            Padding="20"
            Background="#E8F5E9"
            CornerRadius="10"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <StackPanel Spacing="10">
                <TextBlock
                    Text="Register"
                    FontSize="24"
                    HorizontalAlignment="Center"
                    Foreground="#389e7c"
                    Margin="0,0,0,10">
 
                </TextBlock>
                <TextBox
                    PlaceholderText="Email"
                    PlaceholderForeground="#389e7c"
                    BorderBrush="#389e7c"
                    Text="{Binding Email, Mode=TwoWay}">
                    <TextBox.Resources>
                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#389e7c"/>
                    </TextBox.Resources>
                </TextBox>

                <TextBox
                    PlaceholderText="Phone number (optional)"
                    PlaceholderForeground="#389e7c"
                    BorderBrush="#389e7c"

                    Text="{Binding PhoneNumber, Mode=TwoWay}">
                    <TextBox.Resources>
                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#389e7c"/>
                    </TextBox.Resources>
                </TextBox>

                <TextBox
                    PlaceholderText="Username (optional)"
                    PlaceholderForeground="#389e7c"
                    BorderBrush="#389e7c"
                    Text="{Binding Username, Mode=TwoWay}">
                    <TextBox.Resources>
                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#389e7c"/>
                    </TextBox.Resources>
                </TextBox>

                <PasswordBox
                    x:Name="PasswordBox"
                    PlaceholderText="Password"
                    PasswordChanged="PasswordBox_PasswordChanged">
                    <PasswordBox.Resources>
                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#389e7c"/>
                    </PasswordBox.Resources>
                </PasswordBox>
                
                <PasswordBox
                    x:Name="ConfirmPasswordBox"
                    PlaceholderText="Confirm Password"
                    PasswordChanged="ConfirmPasswordBox_PasswordChanged">
                    <PasswordBox.Resources>
                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#389e7c"/>
                    </PasswordBox.Resources>
                </PasswordBox>

                <Button
                    Content="Register"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,0"
                    Background="#389e7c"
                    Foreground="White"
                    BorderBrush="Gray"
                    Command="{Binding RegisterCommand}">
                </Button>

                <TextBlock HorizontalAlignment="Center">
                    <Run Text="Already have an account?" Foreground="Black"></Run>
                    <Hyperlink Click="Login_Click">
                        <Run Foreground="#389e7c">Login</Run>
                    </Hyperlink>
                </TextBlock>



            </StackPanel>
        
        
        
        
        </Border>
        
        
    </Grid>
</Page>
