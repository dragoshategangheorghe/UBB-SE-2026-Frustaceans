<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PharmacyApp.Features.Accounts.Views.RegisterView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PharmacyApp.Features.Accounts.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>

        <!-- Normal -->
        <SolidColorBrush x:Key="TextControlBackground" Color="Gray"/>

        <!-- Hover -->
        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Black"/>

        <!-- Focus -->
        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Gray"/>

    </Page.Resources>

    <Grid Background="White">
        <Border
            Width="320"
            Padding="20"
            Background="LightGray"
            CornerRadius="10"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <StackPanel Spacing="10">
                <TextBlock
                    Text="Register"
                    FontSize="24"
                    HorizontalAlignment="Center"
                    Foreground="Black"
                    Margin="0,0,0,10">
 
                </TextBlock>
                <TextBox
                    PlaceholderText="Email"
                    Text="{Binding Email, Mode=TwoWay}">
                </TextBox>

                <TextBox
                    PlaceholderText="Phone number (optional)"
                    Text="{Binding PhoneNumber, Mode=TwoWay}">
                </TextBox>

                <TextBox
                    PlaceholderText="Username (optional)"
                    Text="{Binding Username, Mode=TwoWay}">
                </TextBox>

                <PasswordBox
                    x:Name="PasswordBox"
                    PlaceholderText="Password"
                    PasswordChanged="PasswordBox_PasswordChanged">
                </PasswordBox>
                
                <PasswordBox
                    x:Name="ConfirmPasswordBox"
                    PlaceholderText="Confirm Password"
                    PasswordChanged="ConfirmPasswordBox_PasswordChanged">
                </PasswordBox>

                <Button
                    Content="Register"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,0"
                    Background="#F0F0F0"
                    Foreground="Black"
                    BorderBrush="Gray"
                    Command="{Binding RegisterCommand}">
                </Button>

                <TextBlock HorizontalAlignment="Center">
                    <Run Text="Already have an account? "/>
                    <Hyperlink Click="Login_Click">
                        <Run Text="Login"/>
                    </Hyperlink>
                </TextBlock>



            </StackPanel>
        
        
        
        
        </Border>
        
        
    </Grid>
</Page>
