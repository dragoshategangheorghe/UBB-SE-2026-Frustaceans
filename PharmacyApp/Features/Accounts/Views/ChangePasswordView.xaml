<ContentDialog
    x:Class="PharmacyApp.Features.Accounts.Views.ChangePasswordView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Change Password"
    PrimaryButtonText="Change Password"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    PrimaryButtonClick="ContentDialog_PrimaryButtonClick">

    <StackPanel Spacing="12">

        <!-- Error -->
        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="Red"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

        <PasswordBox x:Name="OldPasswordBox" Header="Old Password"/>
        <PasswordBox x:Name="NewPasswordBox" Header="New Password"/>
        <PasswordBox x:Name="ConfirmPasswordBox" Header="Confirm Password"/>

    </StackPanel>

</ContentDialog>