<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PharmacyApp.Features.Accounts.Views.ProfileManagementView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PharmacyApp.Features.Accounts.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>

        <!--for the box-->
        <SolidColorBrush x:Key="TextControlBackground" Color="White"/>
        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#389e7c"/>
        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="White"/>


        <!--for the text-->
        <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#389e7c"></SolidColorBrush>
        <SolidColorBrush x:Key="TextControlForeground" Color="#389e7c"></SolidColorBrush>
        <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="White"></SolidColorBrush>
        <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#389e7c"></SolidColorBrush>
        <SolidColorBrush x:Key="TextControlSelectionHighlightColor" Color="#389e7c"></SolidColorBrush>

        <!--button stuff-->
        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#C8E6C9"/>
        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#C8E6C9"/>

    </Page.Resources>
    <Grid Background="White">
        <Border
            Padding="20"
            Background="#E8F5E9"
            CornerRadius="10"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
            <StackPanel Spacing="12" Padding="20" MaxWidth="400">

                <TextBlock Text="My Profile"
                   FontSize="24"
                   Foreground="#389e7c"
                   FontWeight="Bold"/>



                <TextBlock
                           Text="Email"
                           Foreground="#389e7c">
                </TextBlock>
                <TextBox
                 Text="{Binding Email}"
                 IsReadOnly="True"
                    BorderBrush="#389e7c">
                    <TextBox.Resources>
                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#389e7c"/>
                    </TextBox.Resources>
                </TextBox>

                <TextBlock
                           Text="Username"
                           Foreground="#389e7c">
                </TextBlock>
                <TextBox
                 Text="{Binding Username, Mode=TwoWay}"
                    BorderBrush="#389e7c">
                    <TextBox.Resources>
                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#389e7c"/>
                    </TextBox.Resources>
                </TextBox>

                <TextBlock
                           Text="Phone Number"
                           Foreground="#389e7c">
                </TextBlock>
                <TextBox
                 Text="{Binding PhoneNumber, Mode=TwoWay}"
                    BorderBrush="#389e7c">
                    <TextBox.Resources>
                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#389e7c"/>
                    </TextBox.Resources>
                </TextBox>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Content="Change Password"
                        Background="#389e7c"
                        Foreground="White"
                        BorderBrush="Gray"
                        Click="OnChangePasswordClick">
                       
                    </Button>
                    <Button Content="Order History"
                        Background="#389e7c"
                        Foreground="White"
                        BorderBrush="Gray"
                        Click="OnOrderHistoryClick">

                    </Button>


                </StackPanel>



                <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="Red"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
                
                
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Content="Save Changes"
                    Background="#389e7c"
                    Foreground="White"
                    BorderBrush="Gray"
                    Click="OnSaveClick"/>

                    <Button Content="Cancel"
                    Background="#389e7c"
                    Foreground="White"
                    BorderBrush="Gray"
                    Click="OnCancelClick"/>
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Page>
