<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PharmacyApp.Features.Accounts.Views.AdminAccountsManagementView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PharmacyApp.Features.Accounts.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    xmlns:item="using:PharmacyApp.Features.Accounts.ViewModels"
    xmlns:conv="using:PharmacyApp.Common.Converters">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <!--for the box-->
        <SolidColorBrush x:Key="TextControlBackground" Color="White"/>
        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#389e7c"/>
        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="White"/>


        <!--for the text-->
        <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#389e7c"></SolidColorBrush>
        <SolidColorBrush x:Key="TextControlForeground" Color="#389e7c"></SolidColorBrush>
        <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="White"></SolidColorBrush>
        <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#389e7c"></SolidColorBrush>
        <SolidColorBrush x:Key="TextControlSelectionHighlightColor" Color="#389e7c"></SolidColorBrush>

        <!--button stuff-->
        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#C8E6C9"/>
        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#C8E6C9"/>

    </Page.Resources>

    <Grid Padding="20" Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <StackPanel Grid.Row="0" Spacing="10">

            <TextBlock Text="Admin Dashboard"
               FontSize="24"
               FontWeight="SemiBold"
               Foreground="#2F6F5E"/>

            <StackPanel Orientation="Horizontal"
                        Spacing="10">

                <TextBox Width="300"
                         PlaceholderText="Search users..."
                         PlaceholderForeground="#389e7c"
                         Background="#F4F8F6"
                         BorderBrush="#2F6F5E"
                         CornerRadius="6"
                         Text="{Binding SearchQuery, Mode=TwoWay}">
                    <TextBox.Resources>
                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#389e7c"/>
                    </TextBox.Resources>
                </TextBox>

                <Button Content="Search"
                        Background="#2F6F5E"
                        Foreground="White"
                        CornerRadius="6"
                        Click="OnSearchClick">
                </Button>

            </StackPanel>

            <TextBlock Text="{Binding ErrorMessage}"
               Foreground="Red">
                
            </TextBlock>

        </StackPanel>
        
        
        <Border Grid.Row="1"
                Background="#E8F0EA"
                CornerRadius="12"
                Padding="10">
            <ListView 
                ItemsSource="{Binding Users}"
                Background="Transparent"
                BorderThickness="0"
                SelectionMode="None"
                VerticalAlignment="Stretch"
                HorizontalAlignment="Stretch">

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="item:UserItemViewModel">

                            <Border Padding="12" 
                                    Margin="6"
                                    CornerRadius="10"
                                    Background="{x:Bind Background}"
                                    BorderThickness="0">

                                <StackPanel Spacing="6">

                                    <TextBlock Text="{x:Bind Email}"
                                               FontWeight="SemiBold"
                                               FontSize="16"
                                               Foreground="#2F6F5E">
                                    
                                    </TextBlock>

                                    <TextBlock Text="{x:Bind Username}"
                                               Foreground="#4A7D6E">
                                    
                                    </TextBlock>

                                    <TextBlock Text="{x:Bind PhoneNumber}"
                                               Foreground="#4A7D6E">
                                    
                                    </TextBlock>

                                    <TextBlock Text="DISABLED"
                                               Foreground="Red"
                                               FontWeight="Bold"
                                               Visibility="{x:Bind ShowDisabledLabel, Converter={StaticResource BoolToVisibilityConverter}}">
                                    
                                    </TextBlock>

                                    <StackPanel Orientation="Horizontal"
                                                Spacing="10">
                                        <CheckBox Content="Admin"
                                                  Foreground="#2F6F5E"
                                                  Visibility="{x:Bind ShowPromote, Converter={StaticResource BoolToVisibilityConverter}}"
                                                  Tapped="OnPromoteClick">


                                    </CheckBox>

                                        <Button Content="Disable Account"
                                                Background="#2F6F5E"
                                                Foreground="White"
                                                CornerRadius="6"
                                                Padding="10,4"
                                                Visibility="{x:Bind ShowDisable, Converter={StaticResource BoolToVisibilityConverter}}"
                                                Click="OnDisableClick">
                                        
                                        </Button>

                                    </StackPanel>

                                </StackPanel>
                            </Border>

                    </DataTemplate>
                </ListView.ItemTemplate>

            </ListView>
        </Border>


    </Grid>
</Page>
